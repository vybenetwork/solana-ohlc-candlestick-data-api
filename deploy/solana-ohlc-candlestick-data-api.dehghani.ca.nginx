# Nginx vhost for solana-ohlc-candlestick-data-api.dehghani.ca
# Install: sudo cp deploy/solana-ohlc-candlestick-data-api.dehghani.ca.nginx /etc/nginx/sites-available/solana-ohlc-candlestick-data-api.dehghani.ca
#         sudo ln -sf /etc/nginx/sites-available/solana-ohlc-candlestick-data-api.dehghani.ca /etc/nginx/sites-enabled/
#         sudo nginx -t && sudo systemctl reload nginx
# Then get SSL: sudo certbot --nginx -d solana-ohlc-candlestick-data-api.dehghani.ca

server {
    listen 80;
    listen [::]:80;
    server_name solana-ohlc-candlestick-data-api.dehghani.ca;
    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
